# API Keys
TMDB_API_KEY=your_tmdb_api_key_here

# Input Files (relative to project root)
TRAKT_MOVIES_FILE=watched-movies.json
TRAKT_SHOWS_FILE=watched-shows.json

# Output Directory (relative to project root)
OUTPUT_DIR=output

# Cache Directory (relative to project root)
CACHE_DIR=.cache

# Rate Limiting (requests per window)
TMDB_RATE_LIMIT=40
TMDB_RATE_WINDOW=10
ANILIST_RATE_LIMIT=80
ANILIST_RATE_WINDOW=60
JIKAN_RATE_LIMIT=2
JIKAN_RATE_WINDOW=1

# Request Timeout (seconds)
REQUEST_TIMEOUT=15

# Max Retries on failure
MAX_RETRIES=3
